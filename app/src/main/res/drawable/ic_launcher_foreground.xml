<?xml version="1.0" encoding="utf-8"?>
<!--
    Prime Mover launcher glyph. Adaptive icon foreground; geometry sits
    fully inside the 66×66 adaptive-icon safe zone of the 108×108 viewport
    so circular / squircle launchers crop nothing.

    The mark is a four-segment stencil "P" plus a three-segment "M" where
    the right diagonal is the only chromatic accent (signal red).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Letter P (stencil): left vertical, top arm, inner-loop right
         vertical, middle horizontal. Small gaps between segments keep
         the industrial trafaret feel. -->
    <path
        android:fillColor="#0F0F0F"
        android:pathData="M21,22 L29,22 L29,86 L21,86 Z
                          M31,22 L49,22 L49,30 L31,30 Z
                          M41,32 L49,32 L49,50 L41,50 Z
                          M31,52 L49,52 L49,60 L31,60 Z" />

    <!-- Letter M — left vertical + left diagonal (black). -->
    <path
        android:fillColor="#0F0F0F"
        android:pathData="M55,22 L63,22 L63,86 L55,86 Z
                          M63,22 L71,22 L79,58 L71,58 Z" />

    <!-- Letter M — right diagonal (signal red). -->
    <path
        android:fillColor="#D6322D"
        android:pathData="M79,22 L87,22 L79,58 L71,58 Z" />
</vector>
